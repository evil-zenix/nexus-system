# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================
# Формат: {"bot1_name": "TOKEN_1", "bot2_name": "TOKEN_2"}
# Получить токен: https://t.me/BotFather
TELEGRAM_TOKENS='{"moderator_bot": "1234567890:ABCdefGHIjklMNOpqrstUVwxyz", "osint_bot": "0987654321:XYZabcDEFghiJKLmnoPQRstUVwxyz"}'

# ID приватного Telegram-канала для хранения медиа (Storage Channel)
# Получить: https://t.me/userinfobot (используй свой chat_id и сделай бота админом канала)
STORAGE_CHANNEL_ID=-1001234567890

# Webhook конфиг
# Если используется туннель (ngrok/cloudflare): https://yourdomain.com
WEBHOOK_HOST=http://localhost:8000
WEBHOOK_SECRET=your_secret_webhook_token_change_me_in_production

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_NAME=nexus_db
DB_USER=nexus_user
DB_PASSWORD=super_secure_password_change_this_in_production
DATABASE_URL=postgresql+asyncpg://nexus_user:super_secure_password_change_this_in_production@postgres:5432/nexus_db

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://redis:6379/0

# ============================================================================
# LOGGING & ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
# Варианты: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# PGADMIN (опционально, для разработки)
# ============================================================================
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_password_change_me

# ============================================================================
# FEATURE FLAGS & LIMITS (опционально)
# ============================================================================
# Максимальное количество одновременных обработок в воркере
WORKER_MODERATOR_CONCURRENCY=5
WORKER_OSINT_CONCURRENCY=3

# Таймаут обработки задачи (сек)
TASK_TIMEOUT=30

# Максимальный размер сообщения для логирования (байты)
MAX_MESSAGE_SIZE=4096

# Включить ли детальное логирование API запросов
LOG_API_REQUESTS=false
